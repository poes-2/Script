local function skipCinematics()
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    local cb = PlayerGui:FindFirstChild("CinematicBars")
    if cb and cb.Enabled then
        cb.Enabled = false
        for _, gui in ipairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Name ~= "CinematicBars" and gui.Name ~= "GearCinematicBars" and gui.Name ~= "LoadingGui" then
                gui.Enabled = true
            end
        end
    end
    local gcb = PlayerGui:FindFirstChild("GearCinematicBars")
    if gcb and gcb.Enabled then
        gcb.Enabled = false
        for _, gui in ipairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Name ~= "CinematicBars" and gui.Name ~= "GearCinematicBars" and gui.Name ~= "LoadingGui" then
                gui.Enabled = true
            end
        end
    end
end
