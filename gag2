    MutationLabel.Position = UDim2.new(0, 8, 0.7, 0)
    MutationLabel.BackgroundTransparency = 1
    MutationLabel.Text = "✦ Normal"
    MutationLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    MutationLabel.Font = Enum.Font.Gotham
