-- 1. ฟังก์ชันเก็บผลไม้อัจฉริยะ (Collect Fruit)
local function coolectf()
    local MyPlot = GetMyPlot()
    if not MyPlot then return end
    
    for _, _Plant in ipairs(MyPlot.Plants:GetChildren()) do
        if not _Plant:IsA("Model") then continue end
        local _PlantId = _Plant:GetAttribute("PlantId")
        local _Age = tonumber(_Plant:GetAttribute("Age"))
        local _MaxAge = tonumber(_Plant:GetAttribute("MaxAge"))
        
        local _FruitsFolder = _Plant:FindFirstChild("Fruits")
        if not _FruitsFolder or #_FruitsFolder:GetChildren() == 0 then
            if _Age and _MaxAge and _Age >= _MaxAge then
                CollectFruit:Fire(_PlantId, "")
                task.wait(0.02)
            end
        else
            for _, _Fruit in ipairs(_FruitsFolder:GetChildren()) do
                if not _Fruit:IsA("Model") then continue end
                local _FruitId = _Fruit:GetAttribute("FruitId")
                local _FruitAge = tonumber(_Fruit:GetAttribute("Age"))
                local _FruitMaxAge = tonumber(_Fruit:GetAttribute("MaxAge"))
                
                if _FruitId and _FruitAge and _FruitMaxAge and _FruitAge >= _FruitMaxAge then
                    CollectFruit:Fire(_PlantId, _FruitId)
                    task.wait(0.02)
                end
            end
        end
    end
end
-- 2. ฟังก์ชันปลูกผักอัตโนมัติ (Auto Plant)
local function autoPlantAllPlots()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    local plot = workspace.Gardens:FindFirstChild("Plot" .. plotId)
    if not plot then return end
    local allParts = plot:GetDescendants()
    local plantAreas = {}
    
    for _, part in ipairs(allParts) do
        if part:IsA("BasePart") and CollectionService:HasTag(part, "PlantArea") then
            table.insert(plantAreas, part)
        end
    end
    local rng = Random.new()
    for _, part in ipairs(plantAreas) do
        if not _G.AutoPlant then break end
        
        local targetTool = nil
        local seedAttr = nil
        
        for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
            local ats = item:GetAttribute("SeedTool")
            if ats and item.Name ~= "Gold" and item.Name ~= "Rainbow" then
                targetTool = item
                seedAttr = item.Name
                break
            end
        end
        
        if not targetTool then break end
        
        local offsetX = rng:NextNumber(-6, 6)
        local offsetZ = rng:NextNumber(-1.2, 1.2)
        local randomHeight = rng:NextNumber(0.8, 1.3)
        
        local plantPosition = part.Position + Vector3.new(offsetX, randomHeight, offsetZ) 
        
        pcall(function()
            Networking.Plant.PlantSeed:Fire(plantPosition, seedAttr, targetTool)
        end)
        
        task.wait(0.1) 
    end
end
