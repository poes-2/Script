-- 5. ส่งจดหมาย (Send Mail)
local function sand()
    local targetid = tonumber(_G.idpl)
    if not targetid then warn("No target player ID set") return end
    
    local replica = PlayerStateClient:GetLocalReplica()
    if not replica then warn("No Local Replica found") return end
    
    local inventory = replica.Data and replica.Data.Inventory
    if not inventory then return end
    
    local seeds = inventory.Seeds
    if not seeds then return end
    
    local batch = {}
    local itemTypes = {"Gold", "Rainbow"}
    
    for _, name in ipairs(itemTypes) do
        local count = seeds[name] or 0
        if count > 0 then
            table.insert(batch, {
                Category = "Seeds",
                ItemKey = name,
                Count = count
            })
        end
    end
    
    if #batch > 0 then
        pcall(function()
            Networking.Mailbox.SendBatch:Fire(targetid, batch, "Seeds")
            print("Mail Sent Successfully!")
        end)
    else
        print("No Gold or Rainbow seeds to send.")
    end
end
