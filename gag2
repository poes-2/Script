-- 7. วาปเก็บเมล็ด (Teleport Seed Event)
local function tpseedevent()
    local map = workspace:FindFirstChild("Map")
    local locs = map and map:FindFirstChild("SeedPackSpawnServerLocations")
    if locs and #locs:GetChildren() > 0 then
        local hrp, char = getHRP()
        if hrp then
            acquire()
            local saved = hrp.CFrame
            for _, marker in ipairs(locs:GetChildren()) do
                if not _G.EventSeeds then break end
                local cf = marker:IsA("BasePart") and marker.CFrame
                    or (marker:IsA("Model") and marker:GetPivot())
                if cf then
                    hrp.CFrame = cf + Vector3.new(0, 3, 0)
                    task.wait(0.3)
                end
            end
            local hrp2 = getHRP()
            if hrp2 then hrp2.CFrame = saved end
            release()
        end
    end 
end
-- 8. ระบบ Server Hop
local function serverHopHop()
    print("🔍 Searching for low player server...")
    local placeId = game.PlaceId
    local currentJobId = game.JobId
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    local success, response = pcall(function() return game:HttpGet(url) end)
    if success and response then
        local ok, decoded = pcall(function() return HttpService:JSONDecode(response) end)
        if ok and decoded and decoded.data then
            local validServers = {}
            for _, server in pairs(decoded.data) do
                if type(server) == "table" and server.id and server.playing and server.maxPlayers then
                    if server.playing < server.maxPlayers and server.id ~= currentJobId then
                        table.insert(validServers, server)
                    end
                end
            end
            
            table.sort(validServers, function(a, b) return a.playing < b.playing end)
            
            if #validServers > 0 then
                local chooseRange = math.min(#validServers, 3)
                local target = validServers[math.random(1, chooseRange)]
                task.wait(0.5)
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(placeId, target.id, LocalPlayer)
                end)
                return
            end
        end
    end
    pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
end
-- 9. ระบบลดกระตุก (Low Graphics)
local lowGraphicsConnections = {}
local function setLowGraphics(enable)
    if enable then
        game:GetService("Lighting").GlobalShadows = false
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("BasePart") then
                desc.Material = Enum.Material.SmoothPlastic
            elseif desc:IsA("Decal") or desc:IsA("Texture") then
                desc.Transparency = 1
            elseif desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") then
                desc.Enabled = false
            end
        end
        local conn = workspace.DescendantAdded:Connect(function(desc)
            task.wait()
            if desc:IsA("BasePart") then
                desc.Material = Enum.Material.SmoothPlastic
            elseif desc:IsA("Decal") or desc:IsA("Texture") then
                desc.Transparency = 1
            elseif desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") then
                desc.Enabled = false
            end
        end)
        table.insert(lowGraphicsConnections, conn)
        print("Low Graphics Enabled!")
    else
        for _, conn in ipairs(lowGraphicsConnections) do conn:Disconnect() end
        table.clear(lowGraphicsConnections)
        print("Low Graphics Disabled!")
    end
end
