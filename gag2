    CountLabel.Font = Enum.Font.Code
    CountLabel.TextSize = 11
    CountLabel.TextXAlignment = Enum.TextXAlignment.Center
    CountLabel.Parent = Card
    
    return {Count = CountLabel, Mutation = MutationLabel, Icon = Image, Card = Card}
end
-- Stats auto-updater thread
task.spawn(function()
    while ScreenGui.Parent do
        pcall(function()
            local sheckles = LocalPlayer:WaitForChild("leaderstats"):WaitForChild("Sheckles")
            ShecklesValue.Text = "💰 " .. string.format("%s", tostring(sheckles.Value):reverse():gsub("(%d%d%d)","%1,"):reverse():gsub("^,",""))
            
            local replica = PlayerStateClient:GetLocalReplica()
            local seedCount = 0
            
            if replica and replica.Data and replica.Data.Inventory then
                local inv = replica.Data.Inventory
                local seeds = inv.Seeds
                
                for name, count in pairs(seeds) do
                    if count > 0 then
                        seedCount = seedCount + count
                        local card = cardInstances[name]
                        if not card then
                            card = createDynamicCard(name)
                            cardInstances[name] = card
                        end
                        card.Card.Visible = true
                        card.Count.Text = "Count: " .. tostring(count)
                        if name == "Gold" or name:find("Gold") then
                            card.Mutation.Text = "✦ Gold"
                            card.Mutation.TextColor3 = Color3.fromRGB(235, 177, 52)
                        elseif name == "Rainbow" or name:find("Rainbow") then
                            card.Mutation.Text = "✦ Rainbow"
                            card.Mutation.TextColor3 = Color3.fromRGB(166, 75, 255)
                        else
                            card.Mutation.Text = "✦ Normal"
                            card.Mutation.TextColor3 = Color3.fromRGB(200, 200, 200)
                        end
                    else
                        local card = cardInstances[name]
                        if card then
                            card.Card.Visible = false
                        end
                    end
                end
            end
            
            TotalPlantsValue.Text = "🌱 " .. tostring(seedCount)
        end)
        task.wait(1)
    end
end)


