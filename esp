title.Parent = mainFrame



-- === 2. ตั้งค่าตัวแปรควบคุม ===

_G.SpeedEnabled = false

_G.ESPEnabled = false



local speedValue = 200

local jumpPowerValue = 50 -- ปรับเป็น 50 เพื่อให้กระโดดปกติ (ถ้า 10 จะต่ำมาก)



-- === 3. ฟังก์ชันระบบต่าง ๆ ===



-- ระบบ ESP

local function ApplyOverheadESP(player)

    local function CreateGui(character)

        local head = character:WaitForChild("Head", 5)

        if not head then return end

        

        local oldGui = head:FindFirstChild("OverheadESP")

        if oldGui then oldGui:Destroy() end



        local billboard = Instance.new("BillboardGui")

        billboard.Name = "OverheadESP"

        billboard.Parent = head 

        billboard.Adornee = head 

        billboard.Size = UDim2.new(0, 150, 0, 55) 

        billboard.StudsOffset = Vector3.new(0, 3, 0) 

        billboard.AlwaysOnTop = true 



        local layout = Instance.new("UIListLayout")

        layout.Parent = billboard

        layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

        layout.VerticalAlignment = Enum.VerticalAlignment.Bottom



        -- 1. Label สำหรับชื่อ (สีแดง)

        local nameLabel = Instance.new("TextLabel")

        nameLabel.Name = "NameLabel"

        nameLabel.Parent = billboard

        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)

        nameLabel.BackgroundTransparency = 1 

        nameLabel.Text = player.DisplayName 

        nameLabel.TextColor3 = Color3.fromRGB(255, 0, 0) 

        nameLabel.TextScaled = true 

        nameLabel.Font = Enum.Font.GothamBold 

        

        local stroke = Instance.new("UIStroke")

        stroke.Parent = nameLabel

        stroke.Thickness = 1



        -- 2. Label สำหรับพิกัด Position (สร้างเพิ่มตรงนี้)

        local posLabel = Instance.new("TextLabel")

        posLabel.Name = "PosLabel"

        posLabel.Parent = billboard

        posLabel.Size = UDim2.new(1, 0, 0.4, 0)

        posLabel.BackgroundTransparency = 1 

        posLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- สีขาวให้ดูง่าย

        posLabel.TextScaled = true 

        posLabel.Font = Enum.Font.GothamBold 

        

        local stroke2 = Instance.new("UIStroke")

        stroke2.Parent = posLabel

        stroke2.Thickness = 1



        -- อัปเดตตำแหน่งแบบ Real-time

        local connection

        connection = RunService.RenderStepped:Connect(function()

            if not character or not character.Parent or not head then

                connection:Disconnect()

                return

            end



            -- ดึงค่า Position มาทำเป็นตัวเลขไม่มีทศนิยม (%.0f) เพื่อไม่ให้ยาวเกินไป

            local pos = head.Position

            posLabel.Text = string.format("Z: %.0f", pos.Z)

        end)

    end



    if player.Character then task.spawn(function() CreateGui(player.Character) end) end

    player.CharacterAdded:Connect(CreateGui)

end



-- ลูปควบคุม Speed/Jump

task.spawn(function()

    while true do

        if _G.SpeedEnabled then

            local char = LocalPlayer.Character

            local hum = char and char:FindFirstChild("Humanoid")

            if hum then

                hum.WalkSpeed = speedValue

                hum.UseJumpPower = true

                hum.JumpPower = jumpPowerValue

                hum.Jump = true

            end

        end

        task.wait(0.1)

    end

end)



-- === 4. สร้างปุ่มเปิด/ปิด ===

local function createBtn(text, pos)

    local btn = Instance.new("TextButton")

    btn.Size = UDim2.new(0.8, 0, 0, 40)

    btn.Position = pos

    btn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)

    btn.TextColor3 = Color3.fromRGB(255, 255, 255)

    btn.Font = Enum.Font.GothamBold

    btn.Text = text .. ": OFF"

    btn.Parent = mainFrame

    

    -- ใส่ความโค้งให้ปุ่ม

    local corner = Instance.new("UICorner")

    corner.CornerRadius = UDim.new(0, 8)

    corner.Parent = btn

    

    return btn

end



local btnSpeed = createBtn("Speed", UDim2.new(0.1, 0, 0, 50))

local btnESP = createBtn("ESP (Z)", UDim2.new(0.1, 0, 0, 110))



-- เชื่อมปุ่ม Speed

btnSpeed.MouseButton1Click:Connect(function()

    _G.SpeedEnabled = not _G.SpeedEnabled

    btnSpeed.Text = "Speed: " .. (_G.SpeedEnabled and "ON" or "OFF")

    btnSpeed.BackgroundColor3 = _G.SpeedEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(180, 0, 0)

    

    if not _G.SpeedEnabled and LocalPlayer.Character then

        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")

        if hum then hum.WalkSpeed = 16 end -- กลับมาความเร็วปกติ

    end

end)



-- เชื่อมปุ่ม ESP

btnESP.MouseButton1Click:Connect(function()

    _G.ESPEnabled = not _G.ESPEnabled

    btnESP.Text = "ESP: " .. (_G.ESPEnabled and "ON" or "OFF")

    btnESP.BackgroundColor3 = _G.ESPEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(180, 0, 0)

    

    -- อัปเดต ESP ให้คนที่มีอยู่แล้วทันที

    for _, p in pairs(Players:GetPlayers()) do

        if p ~= LocalPlayer and p.Character then

            local head = p.Character:FindFirstChild("Head")

            local gui = head and head:FindFirstChild("OverheadESP")

            if gui then gui.Enabled = _G.ESPEnabled end

        end

    end

end)



-- เริ่มต้นระบบ ESP ให้ผู้เล่นอื่น

for _, p in pairs(Players:GetPlayers()) do

    if p ~= LocalPlayer then ApplyOverheadESP(p) end

end

Players.PlayerAdded:Connect(ApplyOverheadESP)
