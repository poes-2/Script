local lastPress = 0
local function mini()
    local args = {{true,true},"DodgeMinigame"}
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Information"):WaitForChild("RemoteFunction"):FireServer(unpack(args))

    local combat = pGui:FindFirstChild("Combat")
    if combat then
        local block = combat:FindFirstChild("Block")
        local inset = block and block:FindFirstChild("Inset")
        local p1 = inset and inset:FindFirstChild("Indicator")
        local p2 = inset and inset:FindFirstChild("Dodge")
        local s1 = combat:FindFirstChild("Go")

        if p1 and p2 and s1 and block.Visible then
            if isInside(p1, p2) and tick() - lastPress > 0.3 then 
                pressSpacebar()
                lastPress = tick()
            end
        end
    end
end
